{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hub.tribus.dev/schemas/ingestion-payload-1.0.json",
  "title": "Tribus Hub — Ingestion payload",
  "description": "v1.0 · mode create only. Objects array may mix types. Dates: YYYY-MM-DD. User fields: real user UUIDs from workspace.",
  "x-ai-instructions": [
    "Use clear human references when reading user prompts, e.g. PRJ-0007, MS-0002, TSK-0009, CYC-0003, OBJ-0004, KR-0008.",
    "External refs are generated per workspace and per entity type in sequence (PREFIX-0001, PREFIX-0002...).",
    "For new objects in the same payload, prefer client_ref and *_ref links; external_ref is optional and mainly for linking with existing records."
  ],
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "mode", "objects"],
  "properties": {
    "version": { "const": "1.0", "description": "Schema version literal." },
    "mode": { "const": "create", "description": "Only batch create is supported." },
    "objects": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": { "$ref": "#/$defs/ingestionObject" }
    }
  },
  "$defs": {
    "ingestionObject": {
      "oneOf": [
        { "$ref": "#/$defs/okr_cycle_obj" },
        { "$ref": "#/$defs/okr_objective_obj" },
        { "$ref": "#/$defs/okr_key_result_obj" },
        { "$ref": "#/$defs/project_obj" },
        { "$ref": "#/$defs/milestone_obj" },
        { "$ref": "#/$defs/task_obj" }
      ]
    },
    "okr_cycle_obj": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "data"],
      "description": "OKR cycle object. Required: type, data.title, data.start_date, data.end_date.",
      "properties": {
        "type": { "const": "okr_cycle" },
        "client_ref": {
          "type": "string",
          "description": "Unique within payload; for *_ref from other objects."
        },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "start_date", "end_date"],
          "x-required-fields": ["title", "start_date", "end_date"],
          "x-optional-fields": ["external_ref", "description", "status"],
          "properties": {
            "title": { "type": "string", "minLength": 1, "maxLength": 200 },
            "external_ref": { "type": "string", "maxLength": 100 },
            "description": { "type": "string", "maxLength": 2000 },
            "start_date": {
              "type": "string",
              "format": "date",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "end_date": { "type": "string", "format": "date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "status": { "type": "string", "enum": ["planned", "active", "closed"] }
          }
        }
      }
    },
    "okr_objective_obj": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "data"],
      "description": "OKR objective object. Required: type, data.title.",
      "properties": {
        "type": { "const": "okr_objective" },
        "client_ref": { "type": "string" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title"],
          "x-required-fields": ["title"],
          "x-optional-fields": [
            "external_ref",
            "description",
            "cycle_id",
            "cycle_ref",
            "cycle_external_ref",
            "owner_user_id",
            "owner_user_external_ref",
            "status",
            "priority",
            "start_date",
            "target_date"
          ],
          "properties": {
            "title": { "type": "string", "minLength": 1, "maxLength": 500 },
            "external_ref": { "type": "string", "maxLength": 100 },
            "description": { "type": "string", "maxLength": 5000 },
            "cycle_id": { "type": "string" },
            "cycle_ref": { "type": "string" },
            "cycle_external_ref": { "type": "string", "maxLength": 100 },
            "owner_user_id": { "type": "string" },
            "owner_user_external_ref": { "type": "string", "maxLength": 100 },
            "status": {
              "type": "string",
              "enum": ["draft", "on_track", "at_risk", "off_track", "completed"]
            },
            "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
            "start_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "target_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
          }
        }
      }
    },
    "okr_key_result_obj": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "data"],
      "description": "OKR key result object. Required: type, data.title, data.target_value, and one of objective_id/objective_ref/objective_external_ref.",
      "properties": {
        "type": { "const": "okr_key_result" },
        "client_ref": { "type": "string" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "x-required-fields": ["title", "target_value"],
          "x-conditional-required": ["objective_id OR objective_ref OR objective_external_ref"],
          "x-optional-fields": [
            "external_ref",
            "description",
            "objective_id",
            "objective_ref",
            "objective_external_ref",
            "cycle_id",
            "cycle_ref",
            "cycle_external_ref",
            "owner_user_id",
            "owner_user_external_ref",
            "metric_type",
            "unit",
            "start_value",
            "current_value",
            "status",
            "start_date",
            "target_date",
            "confidence",
            "sort_order"
          ],
          "allOf": [
            {
              "required": ["title", "target_value"],
              "properties": {
                "title": { "type": "string", "minLength": 1, "maxLength": 500 },
                "external_ref": { "type": "string", "maxLength": 100 },
                "description": { "type": "string", "maxLength": 5000 },
                "objective_id": { "type": "string" },
                "objective_ref": { "type": "string" },
                "objective_external_ref": { "type": "string", "maxLength": 100 },
                "cycle_id": { "type": "string" },
                "cycle_ref": { "type": "string" },
                "cycle_external_ref": { "type": "string", "maxLength": 100 },
                "owner_user_id": { "type": "string" },
                "owner_user_external_ref": { "type": "string", "maxLength": 100 },
                "metric_type": {
                  "type": "string",
                  "enum": ["percentage", "number", "currency", "boolean", "custom"]
                },
                "unit": { "type": "string", "maxLength": 50 },
                "start_value": { "type": "number" },
                "current_value": { "type": "number" },
                "target_value": { "type": "number" },
                "status": {
                  "type": "string",
                  "enum": ["draft", "on_track", "at_risk", "off_track", "completed"]
                },
                "start_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                "target_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
                "sort_order": { "type": "number" }
              }
            },
            {
              "oneOf": [
                { "required": ["objective_id"] },
                { "required": ["objective_ref"] },
                { "required": ["objective_external_ref"] }
              ]
            }
          ]
        }
      }
    },
    "project_obj": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "data"],
      "description": "Project object. Required: type, data.title.",
      "properties": {
        "type": { "const": "project" },
        "client_ref": { "type": "string" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title"],
          "x-required-fields": ["title"],
          "x-optional-fields": [
            "external_ref",
            "summary",
            "status",
            "health_status",
            "priority",
            "owner_user_id",
            "owner_user_external_ref",
            "cycle_id",
            "cycle_ref",
            "cycle_external_ref",
            "estimation_unit",
            "start_date",
            "target_date"
          ],
          "properties": {
            "title": { "type": "string", "minLength": 1, "maxLength": 500 },
            "external_ref": { "type": "string", "maxLength": 100 },
            "summary": { "type": "string", "maxLength": 1000 },
            "status": {
              "type": "string",
              "enum": ["planned", "active", "on_hold", "completed", "cancelled"]
            },
            "health_status": {
              "type": "string",
              "enum": ["on_track", "at_risk", "blocked", "off_track"]
            },
            "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
            "owner_user_id": { "type": "string" },
            "owner_user_external_ref": { "type": "string", "maxLength": 100 },
            "cycle_id": { "type": "string" },
            "cycle_ref": { "type": "string" },
            "cycle_external_ref": { "type": "string", "maxLength": 100 },
            "estimation_unit": { "type": "string", "enum": ["hours", "story_points"] },
            "start_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "target_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
          }
        }
      }
    },
    "milestone_obj": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "data"],
      "description": "Milestone object. Required: type, data.title, and one of project_id/project_ref/project_external_ref.",
      "properties": {
        "type": { "const": "milestone" },
        "client_ref": { "type": "string" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "x-required-fields": ["title"],
          "x-conditional-required": ["project_id OR project_ref OR project_external_ref"],
          "x-optional-fields": [
            "external_ref",
            "description",
            "project_id",
            "project_ref",
            "project_external_ref",
            "status",
            "priority",
            "owner_user_id",
            "owner_user_external_ref",
            "due_date"
          ],
          "allOf": [
            {
              "required": ["title"],
              "properties": {
                "title": { "type": "string", "minLength": 1, "maxLength": 500 },
                "external_ref": { "type": "string", "maxLength": 100 },
                "description": { "type": "string", "maxLength": 2000 },
                "project_id": { "type": "string" },
                "project_ref": { "type": "string" },
                "project_external_ref": { "type": "string", "maxLength": 100 },
                "status": {
                  "type": "string",
                  "enum": ["pending", "in_progress", "completed", "missed", "blocked"]
                },
                "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
                "owner_user_id": { "type": "string" },
                "owner_user_external_ref": { "type": "string", "maxLength": 100 },
                "due_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
              }
            },
            {
              "oneOf": [
                { "required": ["project_id"] },
                { "required": ["project_ref"] },
                { "required": ["project_external_ref"] }
              ]
            }
          ]
        }
      }
    },
    "task_obj": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "data"],
      "description": "Task object. Required: type, data.title.",
      "properties": {
        "type": { "const": "task" },
        "client_ref": { "type": "string" },
        "data": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title"],
          "x-required-fields": ["title"],
          "x-optional-fields": [
            "external_ref",
            "description",
            "project_id",
            "project_ref",
            "project_external_ref",
            "milestone_id",
            "milestone_ref",
            "milestone_external_ref",
            "column_id",
            "column_name",
            "priority",
            "assignee_user_id",
            "assignee_user_external_ref",
            "due_date",
            "label_ids",
            "estimated_hours",
            "estimated_points"
          ],
          "properties": {
            "title": { "type": "string", "minLength": 1, "maxLength": 500 },
            "external_ref": { "type": "string", "maxLength": 100 },
            "description": { "type": "string", "maxLength": 5000 },
            "project_id": { "type": "string" },
            "project_ref": { "type": "string" },
            "project_external_ref": { "type": "string", "maxLength": 100 },
            "milestone_id": { "type": "string" },
            "milestone_ref": { "type": "string" },
            "milestone_external_ref": { "type": "string", "maxLength": 100 },
            "column_id": { "type": "string" },
            "column_name": { "type": "string" },
            "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
            "assignee_user_id": { "type": "string" },
            "assignee_user_external_ref": { "type": "string", "maxLength": 100 },
            "due_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "label_ids": { "type": "array", "items": { "type": "string" } },
            "estimated_hours": { "type": "number" },
            "estimated_points": { "type": "number" }
          }
        }
      }
    }
  }
}
