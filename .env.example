# ============================================================
# Tribus Hub — Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file with real secrets.
# ============================================================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Tribus Hub"

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/tribus_hub

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Hub API (Cloudflare Worker + D1) — HMAC internal calls
HUB_API_URL=http://127.0.0.1:8788
HUB_API_INTERNAL_SECRET=change-me-internal-secret-16chars-min

# tribus-cds (same JWT secret as Worker `wrangler secret put JWT_SECRET`)
CDS_API_URL=http://127.0.0.1:8787
CDS_JWT_SECRET=must-match-cds-jwt-secret-min-16-chars
CDS_JWT_ISSUER=tribus-cds
CDS_JWT_AUDIENCE=tribus-platform

# Turnstile (optional locally if CDS has no TURNSTILE_SECRET_KEY)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tribus-hub-assets
R2_PUBLIC_URL=https://assets.tribus.com.br

# Upload limits
UPLOAD_MAX_SIZE_BYTES=52428800
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# Email (optional — for future use)
EMAIL_FROM=noreply@tribus.com.br
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
